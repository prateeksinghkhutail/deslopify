{
  "name": "deslopify",
  "version": "1.0.1",
  "description": "Automatic context bloat management for AI developer CLIs (Claude Code, OpenCode)",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "deslopify": "./dist/bin/deslopify.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/bin/deslopify.js",
    "lint": "eslint src/",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "ai",
    "context-management",
    "claude-code",
    "opencode",
    "cli",
    "developer-tools",
    "llm",
    "token-management"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist/",
    "hooks/",
    "plugins/",
    "deslopify.config.example.json",
    "README.md"
  ],
  "dependencies": {
    "chokidar": "^4.0.3",
    "commander": "^13.1.0",
    "sql.js": "^1.11.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@vitest/coverage-v8": "^3.2.4",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
